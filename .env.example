# ETCLOVG Harness Configuration
# Copy this file to .env and fill in your values

# Required: OpenAI API key
OPENAI_API_KEY=sk-your-key-here

# Optional: Alternative env var names (any of these work)
# GPT_KEY=sk-your-key-here
# GPT_API_KEY=sk-your-key-here

# Optional: Custom API base URL (for proxies / Azure / etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Model selection (default: gpt-4o)
# ETCLOVG_MODEL=gpt-4o

# Optional: Agent limits
# ETCLOVG_MAX_ITERATIONS=50
# ETCLOVG_MAX_COST_USD=5.0
